{
    "name": "bytetcore/serpo",
    "description": "Laravel Repository Pattern - Elegant data layer abstraction with criteria-based filtering for Eloquent models.",
    "version": "1.0.0",
    "keywords": [
        "laravel",
        "repository",
        "repository-pattern",
        "eloquent",
        "criteria",
        "filter",
        "query-builder",
        "data-layer"
    ],
    "type": "library",
    "license": "Apache-2.0",
    "autoload": {
        "psr-4": {
            "ByteTCore\\Serpo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ByteTCore\\Serpo\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "ByteTCore",
            "email": "tuando.0598@gmail.com",
            "homepage": "https://github.com/ByteTCore"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "homepage": "https://github.com/ByteTCore/serpo",
    "extra": {
        "laravel": {
            "providers": [
                "ByteTCore\\Serpo\\SerpoServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text",
        "cs": "vendor/bin/pint --test",
        "cs:fix": "vendor/bin/pint"
    },
    "support": {
        "email": "tuando.0598@gmail.com",
        "issues": "https://github.com/ByteTCore/serpo/issues",
        "source": "https://github.com/ByteTCore/serpo",
        "docs": "https://github.com/ByteTCore/serpo"
    },
    "require": {
        "php": "^8.1",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/container": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0|^13.0"
    },
    "config": {
        "sort-packages": true
    }
}